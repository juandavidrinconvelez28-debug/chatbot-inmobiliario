# ============================================================
# VARIABLES DE ENTORNO — Chatbot Inmobiliario WhatsApp
# Copia este archivo como .env y rellena los valores reales.
# NUNCA subas el archivo .env al repositorio.
# ============================================================

# ── SERVIDOR ─────────────────────────────────────────────────
PORT=3000
NODE_ENV=production

# ── META WHATSAPP CLOUD API ───────────────────────────────────
# Token de acceso permanente desde Meta for Developers
WHATSAPP_TOKEN=

# Token de verificación que configuras en el panel de Meta
VERIFY_TOKEN=un_string_secreto_largo_y_aleatorio

# ID del número de teléfono de WhatsApp Business
PHONE_NUMBER_ID=

# ── BASE DE DATOS (PostgreSQL) ────────────────────────────────
# Formato: postgresql://usuario:contraseña@host:puerto/nombre_db
DATABASE_URL=postgresql://usuario:contraseña@host:5432/chatbot_db

# ── NOTIFICACIONES AL ASESOR (opcional) ──────────────────────
# URL de un webhook externo (Zapier, Make, n8n, etc.)
# para recibir alertas cuando entra un nuevo lead o visita.
ADVISOR_WEBHOOK_URL=
