# ============================================================
# .env.example — Variables de entorno
# Copia este archivo como .env y llena los valores reales
# NUNCA subas el archivo .env a git
# ============================================================

# ── SERVIDOR ─────────────────────────────────────────────────
PORT=3000

# ── META / WHATSAPP CLOUD API ─────────────────────────────────
# Obtener en: https://developers.facebook.com/apps/
WHATSAPP_TOKEN=tu_token_de_acceso_permanente
VERIFY_TOKEN=un_string_secreto_para_verificar_el_webhook
PHONE_NUMBER_ID=tu_phone_number_id

# ── TWILIO (alternativa a Meta) ───────────────────────────────
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=tu_twilio_auth_token
TWILIO_WHATSAPP_NUMBER=+14155238886

# ── CRM / INTEGRACIONES EXTERNAS (opcionales) ─────────────────
# HubSpot
HUBSPOT_API_KEY=tu_hubspot_api_key

# Pipedrive
PIPEDRIVE_API_KEY=tu_pipedrive_api_key

# Webhook de notificación a asesor
WEBHOOK_ASESOR_URL=https://tu-crm.com/api/leads/nuevo

# Slack (notificaciones al equipo)
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/xxx/yyy/zzz

# ── BASE DE DATOS (opcional, para persistencia de sesiones) ───
REDIS_URL=redis://localhost:6379
MONGODB_URI=mongodb://localhost:27017/chatbot-inmobiliario
